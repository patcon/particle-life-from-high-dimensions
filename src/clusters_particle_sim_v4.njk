{% extends "sim.njk" %}

{% block title %}Clusters — particle life sim v4{% endblock %}

{% block extraStyle %}
  input[type=number] { background: #1a1a1a; border: 0.5px solid #555; color: #ccc; border-radius: 4px; padding: 2px 4px; font-size: 11px; font-family: monospace; }
  input[type=number]::-webkit-inner-spin-button { opacity: 0.5; }
  .cfg-btn { background: transparent; border: 0.5px solid #555; color: #ccc; border-radius: 6px; padding: 5px 11px; font-size: 13px; cursor: pointer; }
  .cfg-btn:hover { background: #222; }
  @media (min-width: 720px) {
    #right { width: 480px; }
  }
{% endblock %}

{% block extraControls %}
      <label for="cfg-file" style="cursor:pointer;">
        <span class="cfg-btn">load config</span>
        <input type="file" id="cfg-file" accept=".json" style="display:none;"
               onchange="handleConfigFile(this)">
      </label>
{% endblock %}

{% block script %}
const CW = 620, CH = 420;
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

// Speaker particle constants
const S_IDX   = 5;
const S_COLOR = '#FFD700';
let S_RMAX = 200, S_RMIN = 20, S_G = 0.5;

{% include "sim-js-two-canvas.njk" %}

// Shadow initMatrix/initCellState: expand to 6×6 to accommodate S_IDX=5
function initMatrix() {
  mat = Array.from({length: 6}, () => Array.from({length: 6}, rnd));
}

function initCellState() {
  cellState = Array.from({length: 6}, () =>
    Array.from({length: 6}, () => ({
      phase: Math.random() * Math.PI * 2,
      freq:  0.3 + Math.random() * 0.9,
      locked: false
    }))
  );
}

// Shadow step(): two-pass — regular pairs first, then speaker forces
function step() {
  const n = particles.length;
  const ax = new Float32Array(n), ay = new Float32Array(n);
  const RR = R_MAX * R_MAX;

  // Pass 1: regular particle pairs (skip speaker)
  for (let i = 0; i < n; i++) {
    const pi = particles[i];
    if (pi.t === S_IDX) continue;
    for (let j = 0; j < n; j++) {
      if (i === j) continue;
      const pj = particles[j];
      if (pj.t === S_IDX) continue;
      let dx = pj.x - pi.x, dy = pj.y - pi.y;
      if (dx >  CW/2) dx -= CW; else if (dx < -CW/2) dx += CW;
      if (dy >  CH/2) dy -= CH; else if (dy < -CH/2) dy += CH;
      const r2 = dx*dx + dy*dy;
      if (r2 < 0.01 || r2 > RR) continue;
      const r = Math.sqrt(r2);
      const f = r < R_MIN
        ? (r / R_MIN - 1)
        : mat[pi.t][pj.t] * (1 - r / R_MAX);
      const inv = f * G / r;
      ax[i] += dx * inv;
      ay[i] += dy * inv;
    }
  }

  // Pass 2: speaker forces on regular particles (no toroidal wrap — speaker is fixed at center)
  const sp = particles[particles.length - 1];
  const S_RR = S_RMAX * S_RMAX;
  for (let i = 0; i < particles.length - 1; i++) {
    const pi = particles[i];
    const dx = sp.x - pi.x, dy = sp.y - pi.y;
    const r2 = dx*dx + dy*dy;
    if (r2 < 0.01 || r2 > S_RR) continue;
    const r = Math.sqrt(r2);
    const f = r < S_RMIN
      ? (r / S_RMIN - 1)
      : mat[pi.t][S_IDX] * (1 - r / S_RMAX);
    const inv = f * S_G / r;
    ax[i] += dx * inv;
    ay[i] += dy * inv;
  }

  // Integrate (skip speaker — it stays locked)
  for (let i = 0; i < n; i++) {
    const p = particles[i];
    if (p.t === S_IDX) continue;
    p.vx = (p.vx + ax[i]*DT) * DAMPING;
    p.vy = (p.vy + ay[i]*DT) * DAMPING;
    p.x = ((p.x + p.vx*DT) % CW + CW) % CW;
    p.y = ((p.y + p.vy*DT) % CH + CH) % CH;
  }
}

// Shadow draw(): exclude speaker from trail canvas, render it on main canvas
function draw() {
  const trail = +document.getElementById('trail-sl').value;
  tCtx.globalCompositeOperation = 'destination-out';
  tCtx.fillStyle = `rgba(0,0,0,${trail/100})`;
  tCtx.fillRect(0, 0, CW, CH);
  tCtx.globalCompositeOperation = 'source-over';
  for (const p of particles) {
    if (p.t === S_IDX) continue;  // speaker rendered separately, no trail
    tCtx.fillStyle = COLORS[p.t];
    tCtx.beginPath();
    tCtx.arc(p.x, p.y, 2.8, 0, Math.PI*2);
    tCtx.fill();
  }
  ctx.fillStyle = '#080808';
  ctx.fillRect(0, 0, CW, CH);
  ctx.drawImage(trailCanvas, 0, 0);

  // Draw speaker on main canvas each frame (always centered, no trail)
  const sp = particles[particles.length - 1];
  ctx.beginPath();
  ctx.arc(sp.x, sp.y, 10, 0, Math.PI*2);
  ctx.strokeStyle = 'rgba(255,215,0,0.3)';
  ctx.lineWidth = 3;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(sp.x, sp.y, 6, 0, Math.PI*2);
  ctx.fillStyle = S_COLOR;
  ctx.fill();

  if (debug) {
    const toAnnotate = new Set();
    const perSpecies = {};
    for (const p of particles) {
      if (p.t === S_IDX) continue;
      if ((perSpecies[p.t] = (perSpecies[p.t] || 0)) < 5) { toAnnotate.add(p); perSpecies[p.t]++; }
    }
    if (_mouseX !== null) {
      let nearest = null, best = Infinity;
      for (const p of particles) {
        if (p.t === S_IDX) continue;
        const d2 = (p.x-_mouseX)**2 + (p.y-_mouseY)**2;
        if (d2 < best) { best = d2; nearest = p; }
      }
      if (nearest) toAnnotate.add(nearest);
    }
    ctx.lineWidth = 1;
    for (const p of toAnnotate) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, R_MAX, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(34,197,94,0.25)';
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(p.x, p.y, R_MIN, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(216,90,48,0.55)';
      ctx.stroke();
    }
    // Speaker radii always shown in debug mode
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, S_RMAX, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(255,215,0,0.2)';
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, S_RMIN, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(255,215,0,0.5)';
    ctx.stroke();

    const now = performance.now();
    if (_dbgLastT) _dbgFps = _dbgFps * 0.9 + (1000 / (now - _dbgLastT)) * 0.1;
    _dbgLastT = now;
    const lines = [
      `fps    ${_dbgFps.toFixed(1)}`,
      `n      ${particles.length - 1}`,
      `force  ${G.toFixed(2)}`,
      `damp   ${DAMPING.toFixed(2)}`,
      `r-max  ${R_MAX}`,
      `r-min  ${R_MIN}`,
      `s-rmax ${S_RMAX}`,
      `s-rmin ${S_RMIN}`,
      `s-g    ${S_G.toFixed(2)}`,
    ];
    ctx.font = '11px monospace';
    const lh = 15, pad = 8;
    const bw = 110, bh = lines.length * lh + pad;
    ctx.fillStyle = 'rgba(0,0,0,0.65)';
    ctx.fillRect(8, 8, bw, bh);
    ctx.fillStyle = '#378ADD';
    lines.forEach((l, i) => ctx.fillText(l, 8 + pad/2, 8 + pad/2 + 10 + i * lh));
  }
}

// Shadow updateOscillation: also oscillate speaker column cells
function updateOscillation(t) {
  if (!oscillating) return;
  const speed = +document.getElementById('osc-sl').value / 10;
  for (let i = 0; i < nS; i++) {
    for (let j = 0; j < nS; j++) {
      if (cellState[i][j].locked) continue;
      const v = Math.sin(t * cellState[i][j].freq * speed + cellState[i][j].phase);
      mat[i][j] = v;
      const sl = document.getElementById(`sl-${i}-${j}`);
      const vd = document.getElementById(`vd-${i}-${j}`);
      if (sl) { sl.value = v; sl.style.accentColor = v > 0 ? '#22c55e' : '#D85A30'; }
      if (vd) vd.textContent = (v >= 0 ? '+' : '') + v.toFixed(2);
    }
    // Speaker column
    if (!cellState[i][S_IDX].locked) {
      const v = Math.sin(t * cellState[i][S_IDX].freq * speed + cellState[i][S_IDX].phase);
      mat[i][S_IDX] = v;
      const sl = document.getElementById(`sl-${i}-${S_IDX}`);
      const vd = document.getElementById(`vd-${i}-${S_IDX}`);
      if (sl) { sl.value = v; sl.style.accentColor = v > 0 ? '#22c55e' : '#D85A30'; }
      if (vd) vd.textContent = (v >= 0 ? '+' : '') + v.toFixed(2);
    }
  }
}

// Shadow randomizeMatrix: also randomize speaker column for active species
function randomizeMatrix() {
  for (let i = 0; i < 5; i++)
    for (let j = 0; j < 5; j++)
      if (!cellState[i][j].locked) {
        mat[i][j] = rnd();
        cellState[i][j].phase = Math.random() * Math.PI * 2;
        cellState[i][j].freq  = 0.3 + Math.random() * 0.9;
      }
  for (let i = 0; i < nS; i++)
    if (!cellState[i][S_IDX].locked) {
      mat[i][S_IDX] = rnd();
      cellState[i][S_IDX].phase = Math.random() * Math.PI * 2;
      cellState[i][S_IDX].freq  = 0.3 + Math.random() * 0.9;
    }
  renderMatrix();
}

// Shadow resetSettings: also reset speaker params and rebuild speaker sliders
function resetSettings() {
  R_MAX = 80; R_MIN = 13; DT = 0.5; DAMPING = 0.88; G = 1.8;
  S_RMAX = 200; S_RMIN = 20; S_G = 0.5;
  document.getElementById('g-sl').value     = G;
  document.getElementById('damp-sl').value  = DAMPING;
  document.getElementById('rmax-sl').value  = R_MAX;
  document.getElementById('rmin-sl').value  = R_MIN;
  document.getElementById('trail-sl').value = 8;
  renderMatrix();
}

let pps = [60, 60, 60, 60, 60];

function initParticles() {
  particles = [];
  for (let s = 0; s < nS; s++)
    for (let k = 0; k < pps[s]; k++)
      particles.push({x: Math.random()*CW, y: Math.random()*CH, vx:0, vy:0, t:s});
  // Speaker: locked at canvas center, always last in array
  particles.push({x: CW/2, y: CH/2, vx:0, vy:0, t: S_IDX});
}

function loop(ts) {
  const t = ts / 1000;
  if (running) { updateOscillation(t); step(); draw(); }
  requestAnimationFrame(loop);
}

function renderMatrix() {
  let h = `<table class="mat-table"><thead><tr><th></th>`;
  for (let j = 0; j < nS; j++)
    h += `<th><span class="sp-dot" style="background:${COLORS[j]}"></span><span class="sp-label">${NAMES[j]}</span></th>`;
  // Speaker column header (gold dot + S label)
  h += `<th><span class="sp-dot" style="background:${S_COLOR};"></span><span class="sp-label">S</span></th>`;
  h += `</tr>`;
  h += `<tr><td style="font-size:11px;color:#555;text-align:right;padding-right:6px;">count</td>`;
  for (let j = 0; j < nS; j++)
    h += `<td><input type="number" min="1" max="2000" value="${pps[j]}" style="width:52px;"
      id="cnt-${j}" oninput="onCount(${j},+this.value)"></td>`;
  h += `<td></td>`;  // no count input for speaker
  h += `</tr></thead><tbody>`;
  for (let i = 0; i < nS; i++) {
    h += `<tr><td><span class="sp-dot" style="background:${COLORS[i]}"></span><span class="sp-label">${NAMES[i]}</span></td>`;
    for (let j = 0; j < nS; j++) {
      const v = mat[i][j];
      const lk = cellState[i][j].locked;
      h += `<td><div class="mat-cell">
        <input type="range" min="-1" max="1" step="0.05" value="${v}"
          id="sl-${i}-${j}"
          style="width:62px;accent-color:${v>0?'#22c55e':'#D85A30'};"
          oninput="onSlider(${i},${j},+this.value)">
        <div class="mat-val" id="vd-${i}-${j}">${v>=0?'+':''}${v.toFixed(2)}</div>
        <button class="lock-btn${lk?' locked':''}" id="lock-${i}-${j}" onclick="toggleLock(${i},${j})">${lk?'locked':'free'}</button>
      </div></td>`;
    }
    // Speaker reaction column
    const sv = mat[i][S_IDX];
    const slk = cellState[i][S_IDX].locked;
    h += `<td><div class="mat-cell">
      <input type="range" min="-1" max="1" step="0.05" value="${sv}"
        id="sl-${i}-${S_IDX}"
        style="width:62px;accent-color:${sv>0?'#22c55e':'#D85A30'};"
        oninput="onSlider(${i},${S_IDX},+this.value)">
      <div class="mat-val" id="vd-${i}-${S_IDX}">${sv>=0?'+':''}${sv.toFixed(2)}</div>
      <button class="lock-btn${slk?' locked':''}" id="lock-${i}-${S_IDX}" onclick="toggleLock(${i},${S_IDX})">${slk?'locked':'free'}</button>
    </div></td>`;
    h += `</tr>`;
  }
  h += `</tbody></table>`;
  // Speaker physics controls (rebuilt each render to stay in sync with current variable values)
  h += `<div style="margin-top:12px;border-top:1px solid #333;padding-top:10px;">
    <div style="font-size:12px;color:#888;margin-bottom:6px;">speaker physics</div>
    <div style="display:flex;flex-wrap:wrap;gap:7px;align-items:center;">
      <span class="ctrl-pair">
        <label style="font-size:13px;color:#888;" title="Speaker max radius">s-rmax</label>
        <input type="range" min="20" max="400" value="${S_RMAX}" step="5" style="width:60px;" id="srmax-sl"
               oninput="S_RMAX=+this.value">
      </span>
      <span class="ctrl-pair">
        <label style="font-size:13px;color:#888;" title="Speaker inner repulsion radius">s-rmin</label>
        <input type="range" min="2" max="80" value="${S_RMIN}" step="1" style="width:60px;" id="srmin-sl"
               oninput="S_RMIN=+this.value">
      </span>
      <span class="ctrl-pair">
        <label style="font-size:13px;color:#888;" title="Speaker force multiplier">s-force</label>
        <input type="range" min="0.1" max="5" value="${S_G}" step="0.1" style="width:60px;" id="sg-sl"
               oninput="S_G=+this.value">
      </span>
    </div>
  </div>`;
  document.getElementById('mat-wrap').innerHTML = h;
}

function onCount(j, v) {
  pps[j] = Math.max(1, Math.min(2000, v));
  initParticles();
}

function changeSpecies(n) {
  nS = n;
  for (let s = 0; s < n; s++) if (!pps[s]) pps[s] = 60;
  initParticles();
  renderMatrix();
}

function loadConfig(cfg) {
  if (!cfg || typeof cfg.nS !== 'number' || !Array.isArray(cfg.mat)) {
    alert('Invalid config: missing nS or mat fields.'); return;
  }
  const n = cfg.nS;
  if (n < 2 || n > 5) { alert(`Invalid nS: ${n}. Must be 2–5.`); return; }
  if (cfg.mat.length < n || cfg.mat.some(row => !Array.isArray(row) || row.length < n)) {
    alert('Config mat is too small for the specified nS.'); return;
  }
  nS = n;
  for (let i = 0; i < n; i++)
    for (let j = 0; j < n; j++)
      mat[i][j] = cfg.mat[i][j];
  if (cfg.speaker) {
    if (typeof cfg.speaker.rmax === 'number') S_RMAX = cfg.speaker.rmax;
    if (typeof cfg.speaker.rmin === 'number') S_RMIN = cfg.speaker.rmin;
    if (typeof cfg.speaker.g    === 'number') S_G    = cfg.speaker.g;
    if (Array.isArray(cfg.speaker.reactions))
      for (let i = 0; i < Math.min(n, cfg.speaker.reactions.length); i++)
        mat[i][S_IDX] = cfg.speaker.reactions[i];
  }
  if (Array.isArray(cfg.counts) && cfg.counts.length >= n) {
    for (let s = 0; s < n; s++)
      pps[s] = cfg.counts[s];
  }
  const sel = document.getElementById('sel-n');
  if (sel) sel.value = String(n);
  for (let i = 0; i < n; i++)
    for (let j = 0; j < 6; j++)
      cellState[i][j].locked = false;
  initParticles();
  renderMatrix();
}

function handleConfigFile(input) {
  const file = input.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try { loadConfig(JSON.parse(e.target.result)); }
    catch (err) { alert('Failed to parse JSON: ' + err.message); }
  };
  reader.readAsText(file);
  input.value = '';
}

initMatrix();
initCellState();
initParticles();
renderMatrix();
requestAnimationFrame(loop);
{% endblock %}
