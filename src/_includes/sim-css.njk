  :root { --accent: #378ADD; --accent-border: #1a5c9e; }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #111; color: #ccc; padding: 14px; }
  h1 { font-size: 15px; font-weight: 500; color: #aaa; margin-bottom: 10px; letter-spacing: 0.03em; }
  #c { display: block; width: 100%; background: #080808; border-radius: 8px; border: 0.5px solid #333; touch-action: none; cursor: crosshair; }
  #controls { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
  .ctrl-pair { display: inline-flex; align-items: center; gap: 5px; }
  #controls label { font-size: 13px; color: #888; }
  button { background: transparent; border: 0.5px solid #555; color: #ccc; border-radius: 6px; padding: 5px 11px; font-size: 13px; cursor: pointer; }
  button:hover { background: #222; }
  select { background: #1a1a1a; border: 0.5px solid #555; color: #ccc; border-radius: 6px; padding: 4px 8px; font-size: 13px; }
  input[type=range] { accent-color: var(--accent); }
  #mat-section { overflow-x: auto; }
  .mat-table { border-collapse: collapse; font-size: 12px; }
  .mat-table th, .mat-table td { padding: 3px 4px; text-align: center; }
  .mat-cell { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .mat-val { font-size: 11px; font-family: monospace; color: #666; min-width: 36px; }
  .sp-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; vertical-align: middle; margin-right: 3px; }
  .sp-label { color: #888; font-size: 12px; }
  #mat-legend { font-size: 11px; color: #555; margin-top: 6px; }
  .lock-btn { font-size: 10px; padding: 2px 0; width: 62px; color: #555; border: 0.5px solid #3a3a3a; border-radius: 4px; background: transparent; cursor: pointer; letter-spacing: 0.02em; }
  .lock-btn:hover { background: #1e1e1e; }
  .lock-btn.locked { color: #EF9F27; border-color: #6b4a10; background: rgba(239,159,39,0.08); }
  #btn-osc.active { color: var(--accent); border-color: var(--accent-border); }
  #btn-debug.active { color: var(--accent); border-color: var(--accent-border); }
  #btn-wrap.active { color: var(--accent); border-color: var(--accent-border); }
  .osc-speed { display: none; align-items: center; gap: 6px; }
  .osc-speed.visible { display: flex; }
