const trailCanvas = document.createElement('canvas');
trailCanvas.width = CW; trailCanvas.height = CH;
const tCtx = trailCanvas.getContext('2d');

let _dbgLastT = 0, _dbgFps = 0, _mouseX = null, _mouseY = null;

document.addEventListener('DOMContentLoaded', () => {
  const cvs = document.getElementById('c');
  cvs.addEventListener('mousemove', e => {
    const r = cvs.getBoundingClientRect();
    _mouseX = (e.clientX - r.left) * (CW / r.width);
    _mouseY = (e.clientY - r.top)  * (CH / r.height);
  });
  cvs.addEventListener('mouseleave', () => { _mouseX = null; _mouseY = null; });
});

function draw() {
  const trail = +document.getElementById('trail-sl').value;
  // Fade trail canvas toward transparency (avoids integer-rounding artifacts)
  tCtx.globalCompositeOperation = 'destination-out';
  tCtx.fillStyle = `rgba(0,0,0,${trail/100})`;
  tCtx.fillRect(0, 0, CW, CH);
  tCtx.globalCompositeOperation = 'source-over';
  // Draw particles onto trail canvas
  for (const p of particles) {
    tCtx.fillStyle = COLORS[p.t];
    tCtx.beginPath();
    tCtx.arc(p.x, p.y, 2.8, 0, Math.PI*2);
    tCtx.fill();
  }
  // Composite: solid background + trail canvas
  ctx.fillStyle = '#080808';
  ctx.fillRect(0, 0, CW, CH);
  ctx.drawImage(trailCanvas, 0, 0);

  if (debug) {
    // Collect particles to annotate: first 5 per species + nearest to mouse
    const toAnnotate = new Set();
    const perSpecies = {};
    for (const p of particles) {
      if ((perSpecies[p.t] = (perSpecies[p.t] || 0)) < 5) { toAnnotate.add(p); perSpecies[p.t]++; }
    }
    if (_mouseX !== null) {
      let nearest = null, best = Infinity;
      for (const p of particles) {
        const d2 = (p.x-_mouseX)**2 + (p.y-_mouseY)**2;
        if (d2 < best) { best = d2; nearest = p; }
      }
      if (nearest) toAnnotate.add(nearest);
    }
    ctx.lineWidth = 1;
    for (const p of toAnnotate) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, R_MAX, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(34,197,94,0.25)';
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(p.x, p.y, R_MIN, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(216,90,48,0.55)';
      ctx.stroke();
    }

    const now = performance.now();
    if (_dbgLastT) _dbgFps = _dbgFps * 0.9 + (1000 / (now - _dbgLastT)) * 0.1;
    _dbgLastT = now;
    const lines = [
      `fps    ${_dbgFps.toFixed(1)}`,
      `n      ${particles.length}`,
      `force  ${G.toFixed(2)}`,
      `damp   ${DAMPING.toFixed(2)}`,
      `r-max  ${R_MAX}`,
      `r-min  ${R_MIN}`,
    ];
    ctx.font = '11px monospace';
    const lh = 15, pad = 8;
    const bw = 102, bh = lines.length * lh + pad;
    ctx.fillStyle = 'rgba(0,0,0,0.65)';
    ctx.fillRect(8, 8, bw, bh);
    ctx.fillStyle = '#378ADD';
    lines.forEach((l, i) => ctx.fillText(l, 8 + pad/2, 8 + pad/2 + 10 + i * lh));
  }
}
