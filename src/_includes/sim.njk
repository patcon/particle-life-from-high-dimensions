{% extends "base.njk" %}

{% block head %}
<style>
{% include "sim-css.njk" %}
  #layout { display: flex; flex-direction: column; gap: 12px; }
  #left { flex: 1; min-width: 0; }
  #right { display: flex; flex-direction: column; gap: 10px; }
  @media (min-width: 720px) {
    #layout { flex-direction: row; align-items: flex-start; }
    #left { flex: 1; }
    #right { width: 310px; flex-shrink: 0; position: sticky; top: 14px; max-height: calc(100vh - 28px); overflow-y: auto; }
  }
{% block extraStyle %}{% endblock %}
</style>
{% endblock %}

{% block body %}
<div id="layout">
  <div id="left">
    <canvas id="c" width="620" height="420"></canvas>
  </div>
  <div id="right">
    <h1>clusters — particle life</h1>

    <div id="controls">
      <button id="btn-play" onclick="togglePlay()">pause</button>
      <button id="btn-debug" onclick="toggleDebug()">debug</button>
      <button onclick="randomizeMatrix()">randomize forces</button>
      <button onclick="initParticles()">reset positions</button>
      <button onclick="resetSettings()">reset settings</button>
      <button id="btn-osc" onclick="toggleOscillate()">oscillate</button>
      <button id="btn-wrap" class="active" onclick="toggleWrapEdges()">wrap edges</button>
      <span class="ctrl-pair">
        <button onclick="zoomOut()" title="Zoom out">−</button>
        <button onclick="zoomReset()" title="Reset zoom" id="btn-zoom">1×</button>
        <button onclick="zoomIn()" title="Zoom in">+</button>
      </span>
      <div class="osc-speed ctrl-pair" id="osc-speed">
        <label>speed</label>
        <input type="range" min="1" max="20" value="5" step="1" style="width:60px;" id="osc-sl">
      </div>
      <span class="ctrl-pair">
        <label>species</label>
        <select id="sel-n" onchange="changeSpecies(+this.value)" style="width:52px;">
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4" selected>4</option>
          <option value="5">5</option>
        </select>
      </span>
      <span class="ctrl-pair">
        <label>trail</label>
        <input type="range" min="1" max="30" value="8" step="1" style="width:60px;" id="trail-sl">
      </span>
      <hr style="border:none;border-top:1px solid #333;margin:2px 0;width:100%;">
      <span class="ctrl-pair">
        <label title="Force strength multiplier">force</label>
        <input type="range" min="0.1" max="10" value="1.8" step="0.1" style="width:60px;" id="g-sl"
               oninput="G=+this.value">
      </span>
      <span class="ctrl-pair">
        <label title="Velocity damping per frame (lower = more energetic)">damping</label>
        <input type="range" min="0.5" max="0.99" value="0.88" step="0.01" style="width:60px;" id="damp-sl"
               oninput="DAMPING=+this.value">
      </span>
      <span class="ctrl-pair">
        <label title="Maximum interaction radius">r-max</label>
        <input type="range" min="20" max="200" value="80" step="5" style="width:60px;" id="rmax-sl"
               oninput="R_MAX=+this.value">
      </span>
      <span class="ctrl-pair">
        <label title="Minimum repulsion radius">r-min</label>
        <input type="range" min="2" max="40" value="13" step="1" style="width:60px;" id="rmin-sl"
               oninput="R_MIN=+this.value">
      </span>
      {% block extraControls %}{% endblock %}
    </div>

    <div id="mat-section">
      <div id="mat-wrap"></div>
      <div id="mat-legend">row = from &nbsp;·&nbsp; col = to &nbsp;·&nbsp; + attracts &nbsp;·&nbsp; − repels</div>
    </div>
  </div>
</div>

<script>
{% include "sim-js-core.njk" %}
{% block script %}{% endblock %}
</script>
{% endblock %}
